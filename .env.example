# ── Variables de entorno ──────────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores.

# Supabase (pgvector) — obligatorio
SUPABASE_URL=
SUPABASE_KEY=
DB_PASSWORD=

# Backend de IA: "local" (default, usa Ollama) o "cloud" (Groq + Nomic, sin GPU)
BACKEND=local

# Solo si BACKEND=cloud
GROQ_API_KEY=
NOMIC_API_KEY=

# Opcional — overrides de modelo
MODELO_GEN=llama3.2:3b
MODELO_GEN_CLOUD=llama-3.3-70b-versatile
